struct Toast{bool active;uint32_t showMs,durationMs;int x,y,w,h;char msg[40];uint16_t color;};
static Toast g_toast={false,0,0,0,0,0,0,{},TFT_WHITE};
void showToast(const char* msg,uint16_t color=TFT_WHITE,uint32_t dur=1800){
  int tw=tft.width()-2*M,th=18,tx=M,ty=footerY()-th-4;
  tft.fillRect(tx,ty,tw,th,TFT_DARKGREY);tft.drawRect(tx,ty,tw,th,TFT_WHITE);
  tft.setTextFont(1);tft.setTextSize(1);tft.setTextColor(color,TFT_DARKGREY);
  int textW=tft.textWidth(msg);
  tft.setCursor(tx+(tw-textW)/2,ty+5);tft.print(msg);
  g_toast={true,millis(),dur,tx,ty,tw,th,{},color};
  strncpy(g_toast.msg,msg,sizeof(g_toast.msg)-1);g_toast.msg[sizeof(g_toast.msg)-1]='\0';
}
void tickToast(uint32_t now){
  if(!g_toast.active)return;
  if(now-g_toast.showMs>=g_toast.durationMs){
    tft.fillRect(g_toast.x,g_toast.y,g_toast.w,g_toast.h,TFT_BLACK);
    g_toast.active=false;
  }
}

