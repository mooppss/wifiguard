// ═══════════════════════════════════════════════════════════
// Settings screen  (Phase 4, unchanged)
// ═══════════════════════════════════════════════════════════
static int settingsCursor=0;
static const int SETTINGS_ROWS=5;

void cycleSettingValue(int row){
  switch(row){
    case 0:
      if(settings.brightness<50)settings.brightness=50;
      else if(settings.brightness<100)settings.brightness=100;
      else if(settings.brightness<150)settings.brightness=150;
      else if(settings.brightness<200)settings.brightness=200;
      else if(settings.brightness<255)settings.brightness=255;
      else settings.brightness=50;
      applyBrightness(settings.brightness);break;
    case 1:{uint16_t o[]={30,60,120,300};int c=0;
      for(int i=0;i<4;i++)if(settings.sleepSec==o[i]){c=i;break;}
      settings.sleepSec=o[(c+1)%4];break;}
    case 2:settings.sortMode=(SortMode)((settings.sortMode+1)%SORT_COUNT);break;
    case 3:settings.showBSSID=!settings.showBSSID;break;
    case 4:settings.hideHidden=!settings.hideHidden;break;
  }
}
String settingValueStr(int row){
  switch(row){
    case 0:return String(settings.brightness);
    case 1:return String(settings.sleepSec)+"s";
    case 2:return sortModeStr(settings.sortMode);
    case 3:return settings.showBSSID?"On":"Off";
    case 4:return settings.hideHidden?"On":"Off";
    default:return "?";
  }
}
const char* settingLabelStr(int row){
  switch(row){
    case 0:return "Brightness";case 1:return "Sleep after";
    case 2:return "Sort by";case 3:return "Show BSSID";
    case 4:return "Hide hidden";default:return "?";
  }
}
