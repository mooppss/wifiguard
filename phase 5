// ═══════════════════════════════════════════════════════════
// [P5-5] ANALYZE screen — adds "Why?" risk factor bullets
// ═══════════════════════════════════════════════════════════
void showAnalysis(const Net& n) {
  clearContent();
  drawHeader("Analyze");

  int idx   = SAFE_SEL;
  int score = cachedRiskScore(idx);

  drawStatusBox(riskLabel(score) + "  " + String(score) + "/100", riskColor(score));

  int barY = CONTENT_Y + 40, barW = tft.width() - 2*M;
  drawProgressBar(M, barY, barW, 8, score, riskColor(score));

  const int lx = M, vx = M + 66, lineH = 15;
  int y = barY + 14;
  resetTextState(); tft.setTextFont(2); tft.setTextSize(1);

  auto row = [&](const char* label, const String& val,
                 uint16_t valColor, bool withBars = false) {
    tft.setTextColor(TFT_DARKGREY, TFT_BLACK); tft.setCursor(lx, y); tft.print(label);
    if (withBars) {
      tft.setTextColor(valColor, TFT_BLACK); tft.setCursor(vx, y); tft.print(val);
      drawSignalBars(nets[idx].rssi, vx + tft.textWidth(val) + 4, y + 2, TFT_BLACK);
    } else {
      tft.setTextColor(valColor, TFT_BLACK); tft.setCursor(vx, y);
      int maxVW = tft.width() - vx - M; String v = val;
      while (v.length() > 0 && tft.textWidth(v + "..") > maxVW) v.remove(v.length()-1);
      tft.print(v);
    }
    y += lineH;
  };

  row("SSID:",     safeSSID(n.ssid, 16),              TFT_GREEN);
  row("Signal:",   String(n.rssi) + " dBm",           TFT_CYAN,  true);
  row("Security:", encToStr(n.enc),                   TFT_WHITE);
  row("Channel:",  String(n.channel),                 TFT_WHITE);
  row("Portal:",   portalToStr(portalRes[idx]),        portalColor(portalRes[idx]));

  drawLockIcon(n.enc, lx, y - lineH * 3 + 2, TFT_BLACK);

  // ── BSSID (hidden when showBSSID = false) ─────────────
  if (settings.showBSSID) {
    y += 2;
    tft.setTextColor(TFT_DARKGREY, TFT_BLACK);
    tft.setTextFont(2); tft.setTextSize(1); tft.setCursor(lx, y); tft.print("BSSID:");
    tft.setTextFont(1); tft.setTextSize(1); tft.setTextColor(TFT_WHITE, TFT_BLACK);
    String b = n.bssid; b.trim();
    if (b.length() >= 17) {
      tft.setCursor(vx, y);     tft.print(b.substring(0, 8));
      tft.setCursor(vx, y+11);  tft.print(b.substring(9, 17));
      y += 22;
    } else {
      tft.setCursor(vx, y); tft.print(b);
      y += 12;
    }
  } else {
    y += 4;
  }

  // ── [P5-5] "Why?" risk factor bullets ─────────────────
  // Only draw if there's vertical space and factors exist
  const RiskEntry& re = riskCache[idx];
  int numFactors = min((int)re.factorCount, 3);  // top 3

  if (numFactors > 0 && y + 4 + numFactors * 12 < footerY() - 2) {
    // Divider
    tft.drawFastHLine(M, y + 2, tft.width() - 2*M, TFT_DARKGREY);
    y += 6;

    tft.setTextFont(1); tft.setTextSize(1);
    tft.setTextColor(TFT_DARKGREY, TFT_BLACK);
    tft.setCursor(lx, y); tft.print("Why:");
    y += 10;

    for (int i = 0; i < numFactors; i++) {
      const RiskFactor& f = re.factors[i];
      if (y + 10 >= footerY() - 2) break;

      // Bullet
      tft.setTextColor(TFT_DARKGREY, TFT_BLACK);
      tft.setCursor(lx, y); tft.print("\x07 ");   // bullet char (font 1)

      // Label
      tft.setTextColor(TFT_WHITE, TFT_BLACK);
      tft.setCursor(lx + 8, y);
      // Fit label
      String lbl = String(f.label);
      int maxLblW = tft.width() - lx - 8 - M - 24;
      while (lbl.length() > 0 && tft.textWidth(lbl) > maxLblW) lbl.remove(lbl.length()-1);
      tft.print(lbl);

      // Delta value right-aligned
      char buf[8];
      snprintf(buf, sizeof(buf), "%+d", (int)f.delta);
      uint16_t dColor = (f.delta > 0) ? TFT_RED : TFT_GREEN;
      tft.setTextColor(dColor, TFT_BLACK);
      int dw = tft.textWidth(buf);
      tft.setCursor(tft.width() - M - dw, y);
      tft.print(buf);

      y += 11;
    }
  }

  drawFooterHint("L: Back    Both: Portal", "R: Next");
}

