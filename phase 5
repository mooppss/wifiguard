void drawListPanel(){
  if(netCount<=0)return;
  int w=tft.width(),pX=M,pY=listPanelY(),pW=w-2*M,pH=footerY()-pY-2;
  if(pH<LP_ROWS*12)return;
  int rowH=(pH-2*LP_PAD)/LP_ROWS;
  tft.drawRect(pX,pY,pW,pH,TFT_WHITE);tft.fillRect(pX+1,pY+1,pW-2,pH-2,TFT_BLACK);
  const int COL_LOCK=pX+4,LOCK_W=10,COL_SSID=pX+4+LOCK_W+4;
  const int COL_BARS=pX+pW-4-15-4-24,COL_TAG=pX+pW-4-24;
  const int SSID_MAXW=COL_BARS-COL_SSID-2;
  for(int i=0;i<LP_ROWS;i++){
    if(i>=netCount)break;
    int idx=(SAFE_SEL+i)%netCount,ry=pY+LP_PAD+i*rowH;
    bool isSel=(i==0);
    uint16_t rowBg=isSel?(uint16_t)TFT_DARKGREY:(uint16_t)TFT_BLACK;
    uint16_t rowFg=isSel?(uint16_t)TFT_BLACK:(uint16_t)TFT_WHITE;
    tft.fillRect(pX+2,ry,pW-4,rowH,rowBg);
    drawLockIcon(nets[idx].enc,COL_LOCK,ry+(rowH-12)/2,rowBg);
    drawFittedText(nets[idx].ssid,COL_SSID,ry+(rowH-14)/2,SSID_MAXW,rowFg,rowBg);
    drawSignalBars(nets[idx].rssi,COL_BARS,ry+(rowH-9)/2,rowBg);
    tft.setTextFont(1);tft.setTextSize(1);
    // [P5-6] NEW tag overrides sec tag when isNew
    if(isNew[idx]){
      tft.setTextColor(TFT_MAGENTA,rowBg);
      tft.setCursor(COL_TAG,ry+(rowH-8)/2);tft.print("NEW!");
    } else {
      tft.setTextColor(isSel?(uint16_t)TFT_DARKGREY:(uint16_t)TFT_CYAN,rowBg);
      tft.setCursor(COL_TAG,ry+(rowH-8)/2);tft.print(encTag(nets[idx].enc));
    }
  }
}

