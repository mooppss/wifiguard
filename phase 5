    case WIFI_AUTH_WPA2_WPA3_PSK: return "W2/3"; default: return "UNK ";
  }
}
String safeSSID(const String& s, int maxChars) {
  String t=s; t.trim();
  if (t.length()==0) return "(hidden)";
  String out=""; bool rem=false;
  for (int i=0;i<(int)t.length();i++){
    char c=t[i];
    if (c>=32&&c<=126) out+=c; else rem=true;
  }
  if (out.length()==0) return rem?"(non-ascii)":"(hidden)";
  if ((int)out.length()>maxChars) out=out.substring(0,maxChars-2)+"..";
  return out;
}
String bssidSuffix(const String& bssid) {
  if (!settings.showBSSID) return "";
  if (bssid.length()<17) return "";
  return bssid.substring(12);
}
String portalToStr(PortalResult pr) {
  switch (pr) {
    case PORTAL_NOT_TESTED: return "Not tested"; case PORTAL_NO_PORTAL: return "No portal";
    case PORTAL_PORTAL_LIKELY: return "Portal likely"; case PORTAL_NO_INTERNET: return "No internet";
    case PORTAL_CONNECT_FAIL: return "Connect fail"; case PORTAL_NEEDS_PASSWORD: return "Needs password";
