// ═══════════════════════════════════════════════════════════
// Sort  (Phase 4 — now calls cachedRiskScore for SORT_RISK)
// ═══════════════════════════════════════════════════════════
void swapNet(int a, int b) {
  Net tmp=nets[a]; nets[a]=nets[b]; nets[b]=tmp;
  PortalResult ptmp=portalRes[a]; portalRes[a]=portalRes[b]; portalRes[b]=ptmp;
  RiskEntry rtmp=riskCache[a]; riskCache[a]=riskCache[b]; riskCache[b]=rtmp;
  bool ntmp=isNew[a]; isNew[a]=isNew[b]; isNew[b]=ntmp;
}

void sortNets() {
  if (netCount<=1) return;
  for (int i=1;i<netCount;i++){
    int j=i;
    while (j>0){
      bool doSwap=false;
      switch (settings.sortMode){
        case SORT_RSSI:    doSwap=(nets[j].rssi>nets[j-1].rssi); break;
        case SORT_RISK:    doSwap=(cachedRiskScore(j)>cachedRiskScore(j-1)); break;
        case SORT_OPEN: {
          bool jO=(nets[j].enc==WIFI_AUTH_OPEN), j1O=(nets[j-1].enc==WIFI_AUTH_OPEN);
          if (jO&&!j1O) doSwap=true;
          else if (jO==j1O) doSwap=(nets[j].rssi>nets[j-1].rssi);
          break;
        }
        case SORT_CHANNEL: doSwap=(nets[j].channel<nets[j-1].channel); break;
        default: break;
      }
      if (doSwap){swapNet(j,j-1);j--;} else break;
    }
  }
  sel=0;
}

// ═══════════════════════════════════════════════════════════
// Battery
// ═══════════════════════════════════════════════════════════
float readBatteryVoltage() {
  const int N=20; uint32_t sum=0;
  for (int i=0;i<N;i++){sum+=analogRead(BAT_ADC);delay(2);}
  return (sum/(float)N/4095.0f)*3.3f*2.0f*1.05f;
}
int batteryPct(float v) {
  if (v>=4.20f) return 100; if (v<=3.00f) return 0;
  return (int)((v-3.00f)*(100.0f/1.20f));
}

