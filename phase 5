// ═══════════════════════════════════════════════════════════
// [P5-1] RiskFactor + RiskCache
// ═══════════════════════════════════════════════════════════
struct RiskFactor {
  char    label[24];
  int8_t  delta;
};

static const int MAX_FACTORS = 5;

struct RiskEntry {
  int8_t     score;        // −1 = not computed yet
  uint8_t    factorCount;
  RiskFactor factors[MAX_FACTORS];
};

RiskEntry riskCache[25];

// Invalidate all cache entries (called before computeAllRisk)
void invalidateRiskCache() {
  for (int i = 0; i < 25; i++) {
    riskCache[i].score = -1;
    riskCache[i].factorCount = 0;
  }
}

// ═══════════════════════════════════════════════════════════
// [P5-6] NEW marker data
// ═══════════════════════════════════════════════════════════
uint64_t prevBSSIDs[25];   // packed from previous scan; zero = not seen
bool     isNew[25];        // true if this BSSID wasn't in prevBSSIDs

// Pack BSSID string "AA:BB:CC:DD:EE:FF" → uint64_t (bottom 6 bytes)
uint64_t packBSSID(const String& b) {
  if (b.length() < 17) return 0ULL;
  uint64_t v = 0;
  // parse 6 hex pairs
  const char* p = b.c_str();
  for (int i = 0; i < 6; i++) {
    uint8_t hi = p[i*3],   lo = p[i*3+1];
    auto hexNib = [](char c) -> uint8_t {
      if (c >= '0' && c <= '9') return c - '0';
      if (c >= 'A' && c <= 'F') return c - 'A' + 10;
      if (c >= 'a' && c <= 'f') return c - 'a' + 10;
      return 0;
    };
    v = (v << 8) | ((hexNib(hi) << 4) | hexNib(lo));
  }
  return v;
}

// Called after scan to mark new APs
void updateNewMarkers() {
  for (int i = 0; i < netCount; i++) {
    uint64_t packed = packBSSID(nets[i].bssid);
    isNew[i] = true;
    if (packed == 0ULL) { isNew[i] = false; continue; }
    for (int j = 0; j < 25; j++) {
      if (prevBSSIDs[j] == packed) { isNew[i] = false; break; }
    }
  }
  // Save current BSSIDs as previous for next scan
  memset(prevBSSIDs, 0, sizeof(prevBSSIDs));
  for (int i = 0; i < netCount && i < 25; i++)
    prevBSSIDs[i] = packBSSID(nets[i].bssid);
}

// ═══════════════════════════════════════════════════════════
// [P5-3] Channel congestion helper
//
//  channelCounts[ch] = number of APs on that channel (1-indexed, [0] unused)
//  overlapCount(ch)  = APs on channels that could interfere with ch
//  (2.4GHz channels overlap if |ch_a - ch_b| <= 4)
// ═══════════════════════════════════════════════════════════
static int channelCounts[15] = {0};  // index 1–14 used; index 0 unused

void buildChannelCounts() {
  memset(channelCounts, 0, sizeof(channelCounts));
  for (int i = 0; i < netCount; i++) {
    int ch = nets[i].channel;
    if (ch >= 1 && ch <= 14) channelCounts[ch]++;
    // 5GHz channels are far apart, skip congestion penalty for ch > 14
  }
}

int overlapCount(int ch) {
  if (ch < 1 || ch > 14) return 0;
  int total = 0;
  for (int c = max(1, ch - 4); c <= min(14, ch + 4); c++) {
    if (c != ch) total += channelCounts[c];
  }
  total += channelCounts[ch] - 1;  // other APs on same channel (exclude self)
  return max(0, total);
}

// ═══════════════════════════════════════════════════════════
// [P5-2] computeRisk — fills RiskEntry for nets[idx]
//  Must be called after buildChannelCounts().
// ═══════════════════════════════════════════════════════════

// Helper: add factor if slot available
static void addFactor(RiskEntry& e, const char* label, int8_t delta) {
  if (e.factorCount >= MAX_FACTORS) return;
  strncpy(e.factors[e.factorCount].label, label, 23);
  e.factors[e.factorCount].label[23] = '\0';
  e.factors[e.factorCount].delta = delta;
  e.factorCount++;
}

void computeRisk(int idx) {
  if (idx < 0 || idx >= netCount) return;
  RiskEntry& e   = riskCache[idx];
  const Net&  n  = nets[idx];
  PortalResult pr = portalRes[idx];

  e.score       = 0;
  e.factorCount = 0;

  // ── Encryption ────────────────────────────────────────
  int encScore = 0;
  const char* encLabel = "";
  switch (n.enc) {
    case WIFI_AUTH_OPEN:          encScore = 60; encLabel = "No encryption";    break;
    case WIFI_AUTH_WEP:           encScore = 45; encLabel = "WEP (broken)";     break;
    case WIFI_AUTH_WPA_PSK:       encScore = 22; encLabel = "WPA (weak)";       break;
    case WIFI_AUTH_WPA_WPA2_PSK:  encScore = 20; encLabel = "WPA/WPA2 mixed";   break;
    case WIFI_AUTH_WPA2_PSK:      encScore =  8; encLabel = "WPA2";             break;
    case WIFI_AUTH_WPA3_PSK:      encScore =  3; encLabel = "WPA3 (strong)";    break;
    case WIFI_AUTH_WPA2_WPA3_PSK: encScore =  5; encLabel = "WPA2/WPA3";        break;
    default:                      encScore = 12; encLabel = "Unknown enc";      break;
  }
  if (encScore > 0) { e.score += encScore; addFactor(e, encLabel, encScore); }

  // ── Signal quality ────────────────────────────────────
  int sigScore = 0;
  if      (n.rssi < -85) sigScore = 12;
  else if (n.rssi < -75) sigScore =  8;
  else if (n.rssi < -65) sigScore =  4;
  if (sigScore > 0) { e.score += sigScore; addFactor(e, "Weak signal", sigScore); }

  // ── SSID keywords ─────────────────────────────────────
  String sl = n.ssid; sl.toLowerCase();
  int kwScore = 0; const char* kwLabel = "";
  if      (sl.indexOf("free")      >= 0) { kwScore = 10; kwLabel = "\"free\" in name"; }
  else if (sl.indexOf("starbucks") >= 0) { kwScore =  5; kwLabel = "Coffee shop AP";   }
  else if (sl.indexOf("airport")   >= 0) { kwScore =  5; kwLabel = "Airport AP";       }
  else if (sl.indexOf("hotel")     >= 0) { kwScore =  5; kwLabel = "Hotel AP";         }
  else if (sl.indexOf("public")    >= 0) { kwScore =  5; kwLabel = "Public AP";        }
  else if (sl.indexOf("guest")     >= 0) { kwScore =  5; kwLabel = "Guest network";    }
  else if (sl.indexOf("cafe")      >= 0) { kwScore =  3; kwLabel = "Cafe AP";          }
  if (kwScore > 0) { e.score += kwScore; addFactor(e, kwLabel, kwScore); }

  // ── Portal result ─────────────────────────────────────
  int portalScore = 0; const char* portalLabel = "";
  switch (pr) {
    case PORTAL_PORTAL_LIKELY: portalScore = 15; portalLabel = "Captive portal";   break;
    case PORTAL_NO_INTERNET:   portalScore =  8; portalLabel = "No internet";      break;
    case PORTAL_CONNECT_FAIL:  portalScore =  5; portalLabel = "Connect failed";   break;
    case PORTAL_NO_PORTAL:     portalScore = -5; portalLabel = "Clean (no portal)";break;
    default: break;
  }
  if (portalScore != 0) { e.score += portalScore; addFactor(e, portalLabel, portalScore); }

  // ── Channel congestion ────────────────────────────────
  int ch = n.channel;
  if (ch >= 1 && ch <= 14) {
    int oc = overlapCount(ch);
    int congScore = constrain(oc * 2, 0, 10);
    if (congScore > 0) { e.score += congScore; addFactor(e, "Channel congested", congScore); }
  }

  // ── Final cap ─────────────────────────────────────────
  e.score = constrain(e.score, 0, 100);
}

void computeAllRisk() {
  buildChannelCounts();
  for (int i = 0; i < netCount; i++) computeRisk(i);
}

// ── Accessor helpers (replaces old riskScore / riskScoreWithPortal)
int cachedRiskScore(int idx) {
  if (idx < 0 || idx >= netCount) return 0;
  if (riskCache[idx].score < 0) computeRisk(idx);
  return riskCache[idx].score;
}

// Called from showAnalysis with current sel
int riskScoreForSel() { return cachedRiskScore(SAFE_SEL); }

