void drawSignalBars(int rssi,int x,int y,uint16_t bg=TFT_BLACK){
  const int BAR_W=3,GAP=1,BARS=4,MAX_H=9,WIDGET_W=BARS*BAR_W+(BARS-1)*GAP;
  tft.fillRect(x,y,WIDGET_W,MAX_H+1,bg);
  int ab=(rssi>=-60)?4:(rssi>=-70)?3:(rssi>=-80)?2:1;
  int h4[4]={3,5,7,9};
  for(int i=0;i<BARS;i++){
    int bx=x+i*(BAR_W+GAP),bh=h4[i];
    tft.fillRect(bx,y+MAX_H-bh,BAR_W,bh,(i<ab)?(uint16_t)TFT_GREEN:(uint16_t)TFT_DARKGREY);
  }
}
void drawLockIcon(wifi_auth_mode_t enc,int x,int y,uint16_t bg=TFT_BLACK){
  tft.fillRect(x,y-2,10,15,bg);
  uint16_t col; bool isOpen;
  switch(enc){
    case WIFI_AUTH_OPEN: case WIFI_AUTH_WEP: col=TFT_RED;isOpen=true;break;
    case WIFI_AUTH_WPA_PSK: case WIFI_AUTH_WPA_WPA2_PSK: col=TFT_ORANGE;isOpen=false;break;
    default: col=TFT_GREEN;isOpen=false;break;
  }
  tft.fillRect(x,y+6,10,6,col);tft.fillRect(x+3,y+8,4,3,TFT_BLACK);
  tft.fillRect(x+1,y+1,2,6,col);
  if(!isOpen){tft.fillRect(x+7,y+1,2,6,col);tft.fillRect(x+1,y,8,2,col);}
  else{tft.fillRect(x+7,y-2,2,5,col);}
}
