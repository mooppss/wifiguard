// IndeterBar  (Phase 3)
// ═══════════════════════════════════════════════════════════
struct IndeterBar {
  int x,y,w,h;uint16_t color;int blockPos,blockW;int8_t dir;uint32_t lastTickMs;
  static const int TICK_MS=40,SPEED=5;
  void begin(int _x,int _y,int _w,int _h,uint16_t _c){
    x=_x;y=_y;w=_w;h=_h;color=_c;
    blockW=max(12,_w/4);blockPos=0;dir=1;lastTickMs=0;
    tft.drawRect(x,y,w,h,TFT_WHITE);tft.fillRect(x+1,y+1,w-2,h-2,TFT_DARKGREY);
  }
  void tick(uint32_t now){
    if(now-lastTickMs<(uint32_t)TICK_MS)return;lastTickMs=now;
    int interior=w-2;tft.fillRect(x+1,y+1,interior,h-2,TFT_DARKGREY);
    int bx=x+1+blockPos,bw=min(blockW,interior-blockPos);
    if(bw>0)tft.fillRect(bx,y+1,bw,h-2,color);
    blockPos+=dir*SPEED;
    if(blockPos+blockW>=interior){blockPos=interior-blockW;dir=-1;}
    if(blockPos<=0){blockPos=0;dir=1;}
  }
  void complete(){tft.fillRect(x+1,y+1,w-2,h-2,color);}
  void error(){tft.fillRect(x+1,y+1,w-2,h-2,TFT_RED);}
};

