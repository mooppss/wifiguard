// Buttons  (Phase 1 + 4)
// ═══════════════════════════════════════════════════════════
enum BtnEvent { BTN_NONE, BTN_TAP, BTN_LONG };
static const uint16_t BTN_LONG_THRESH = 800;
static const uint16_t BTN_MAX_WAIT    = 1500;
static const uint16_t BTN_DEBOUNCE_MS = 12;

BtnEvent readBtn(int pin) {
  if (digitalRead(pin) != LOW) return BTN_NONE;
  delay(BTN_DEBOUNCE_MS);
  if (digitalRead(pin) != LOW) return BTN_NONE;
  uint32_t ps = millis(); uint32_t el = 0;
  while (digitalRead(pin) == LOW) {
    el = millis() - ps;
    if (el >= BTN_MAX_WAIT) break;
    delay(5);
  }
  delay(BTN_DEBOUNCE_MS);
  return (el >= BTN_LONG_THRESH) ? BTN_LONG : BTN_TAP;
}

bool chordHeld(uint32_t holdMs = 1000) {
  uint32_t win = millis();
  while (millis() - win < 250) {
    if (digitalRead(BTN_NEXT) == LOW && digitalRead(BTN_ACT) == LOW) break;
    delay(5);
  }
  if (!(digitalRead(BTN_NEXT) == LOW && digitalRead(BTN_ACT) == LOW)) return false;
  uint32_t hs = millis();
  while (millis() - hs < holdMs) {
    if (!(digitalRead(BTN_NEXT) == LOW && digitalRead(BTN_ACT) == LOW)) return false;
    delay(10);
  }
  while (digitalRead(BTN_NEXT) == LOW || digitalRead(BTN_ACT) == LOW) delay(5);
  return true;
}

