  tft.setCursor(w-M-tft.textWidth(val),y+5);tft.print(val);
  if(row==0){
    int barX=w-M-tft.textWidth(val)-40,barY2=y+6,barW=30,barH=6;
    if(barX>M+80){
      tft.drawRect(barX,barY2,barW,barH,isSel?(uint16_t)TFT_WHITE:(uint16_t)TFT_DARKGREY);
      int fill=(barW-2)*settings.brightness/255;
      tft.fillRect(barX+1,barY2+1,fill,barH-2,TFT_YELLOW);
    }
  }
}
void showSettings(){
  clearContent();drawHeader("Settings");
  for(int i=0;i<SETTINGS_ROWS;i++)drawSettingsRow(i);
  tft.drawFastHLine(M,footerY()-2,tft.width()-2*M,TFT_DARKGREY);
  drawFooterHint("L: Change","R: Next / Save");
}

// ═══════════════════════════════════════════════════════════
// doScanList  (Phase 4 + P5 additions: updateNewMarkers,
//              invalidateRiskCache, computeAllRisk)
// ═══════════════════════════════════════════════════════════
void doScanList(){
  netCount=0;sel=0;
  clearContent();drawHeader("WiFiGuard");drawFooterHint("","");
  resetTextState();
  tft.setTextColor(TFT_WHITE,TFT_BLACK);tft.setCursor(M,CONTENT_Y+14);
  tft.print(hasScannedOnce?"Rescanning...":"Scanning...");
  tft.setTextFont(1);tft.setTextSize(1);tft.setTextColor(TFT_DARKGREY,TFT_BLACK);
  tft.setCursor(M,CONTENT_Y+32);tft.print("Looking for networks nearby");

  int barW=tft.width()-2*M;
  IndeterBar bar;bar.begin(M,CONTENT_Y+48,barW,12,TFT_CYAN);

  WiFi.mode(WIFI_STA);WiFi.disconnect(true,true);delay(100);
  WiFi.scanNetworks(true,true);

  const uint32_t SCAN_TIMEOUT_MS=12000;
  uint32_t t0=millis();int scanResult=WIFI_SCAN_RUNNING;
  while(true){
    uint32_t now=millis();bar.tick(now);
    scanResult=WiFi.scanComplete();
    if(scanResult>=0||scanResult==WIFI_SCAN_FAILED)break;
    if(now-t0>=SCAN_TIMEOUT_MS){WiFi.scanDelete();scanResult=-1;break;}
    delay(20);
  }

  if(scanResult<=0){
    bar.error();delay(400);
    clearContent();drawHeader("WiFiGuard");
    drawStatusBox("NO NETWORKS FOUND",TFT_RED);drawFooterHint("","R: Retry");
    WiFi.scanDelete();showToast("No networks found",TFT_RED,2000);return;
  }
  bar.complete();delay(120);

  int raw=min(scanResult,25);netCount=0;
  for(int i=0;i<raw;i++){
    String ssid=WiFi.SSID(i);
    if(settings.hideHidden){
      String safe=safeSSID(ssid,64);
      if(safe=="(hidden)"||safe=="(non-ascii)")continue;
    }
    if(netCount>=25)break;
    nets[netCount].ssid=ssid;nets[netCount].rssi=WiFi.RSSI(i);
    nets[netCount].enc=WiFi.encryptionType(i);nets[netCount].bssid=WiFi.BSSIDstr(i);
    nets[netCount].channel=WiFi.channel(i);portalRes[netCount]=PORTAL_NOT_TESTED;
    netCount++;
  }
  WiFi.scanDelete();

  // [P5-6] Mark new APs (uses prevBSSIDs from last scan)
  updateNewMarkers();

  // [P5-2/5-3] Compute risk scores + channel congestion for all nets
  invalidateRiskCache();
  computeAllRisk();

  // [P4-4] Sort (uses cachedRiskScore for SORT_RISK)
  sortNets();

  hasScannedOnce=true;
  showList();
  char tm[32];snprintf(tm,sizeof(tm),"Found %d network%s",netCount,netCount==1?"":"s");
  showToast(tm,TFT_CYAN,1800);
}

// ═══════════════════════════════════════════════════════════
// runPortalTest  (Phase 3/4 + P5: recompute risk after portal)
// ═══════════════════════════════════════════════════════════
PortalResult runPortalTest(const Net& n){
  if(n.enc!=WIFI_AUTH_OPEN){
    showToast("Portal: needs password",TFT_DARKGREY,1600);return PORTAL_NEEDS_PASSWORD;
  }
  clearContent();drawHeader("Portal Test");drawFooterHint("","");
  resetTextState();tft.setTextColor(TFT_WHITE,TFT_BLACK);
  tft.setCursor(M,CONTENT_Y+14);tft.print("Connecting to:");
  drawFittedText(n.ssid,M,CONTENT_Y+30,tft.width()-2*M,TFT_YELLOW,TFT_BLACK);

  int barW=tft.width()-2*M;
  IndeterBar bar;bar.begin(M,CONTENT_Y+52,barW,12,TFT_YELLOW);
  WiFi.mode(WIFI_STA);WiFi.disconnect(true);delay(150);WiFi.begin(n.ssid.c_str());
  uint32_t t0=millis();
  while(WiFi.status()!=WL_CONNECTED&&millis()-t0<9000){bar.tick(millis());delay(20);}
  if(WiFi.status()!=WL_CONNECTED){
    bar.error();delay(300);WiFi.disconnect(true);
    showToast("Connect failed",TFT_RED,1800);return PORTAL_CONNECT_FAIL;
  }
  tft.setTextFont(1);tft.setTextSize(1);tft.setTextColor(TFT_DARKGREY,TFT_BLACK);
  tft.setCursor(M,CONTENT_Y+52+18);tft.print("Connected. Checking internet...");
  for(int i=0;i<5;i++){bar.tick(millis());delay(60);}

  HTTPClient http;
  http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);http.setTimeout(6000);
  http.begin("http://connectivitycheck.gstatic.com/generate_204");
  int code=http.GET();http.end();WiFi.disconnect(true);
  bar.complete();delay(150);

  PortalResult result;
  if(code==204)result=PORTAL_NO_PORTAL;
  else if(code<=0)result=PORTAL_NO_INTERNET;
  else result=PORTAL_PORTAL_LIKELY;

  // [P5-7] Recompute risk for this AP now that portal result is known
  computeRisk(SAFE_SEL);

  showToast(portalToStr(result),portalColor(result),1800);
  return result;
}

// ═══════════════════════════════════════════════════════════
// Idle animation + sleep
// ═══════════════════════════════════════════════════════════
void idleTickAnimation(ScreenState s){
  if(!(s==HOME||s==LIST||s==ANALYZE))return;
  if(millis()-lastIdleAnimMs<6000)return;lastIdleAnimMs=millis();
  int x=tft.width()-34,y=footerY()-14;
  tft.fillRect(x,y,30,10,TFT_BLACK);tft.setTextFont(1);tft.setTextSize(1);
  tft.setTextColor(TFT_DARKGREY,TFT_BLACK);tft.setCursor(x,y+2);
  idleFrame=(idleFrame+1)%3;
  if(idleFrame==0)tft.print(".");if(idleFrame==1)tft.print("..");if(idleFrame==2)tft.print("...");
}

void goToSleep(){
  tft.fillScreen(TFT_BLACK);resetTextState();
  tft.setTextColor(TFT_DARKGREY,TFT_BLACK);tft.setCursor(M,60);tft.print("Sleeping...");
  delay(300);applyBrightness(0);
  esp_sleep_enable_ext0_wakeup((gpio_num_t)BTN_ACT,0);esp_deep_sleep_start();
}

// ═══════════════════════════════════════════════════════════
// Setup
// ═══════════════════════════════════════════════════════════
void setup(){
  Serial.begin(115200);
  initBacklight();
  loadSettings();
  applyBrightness(settings.brightness);
  pinMode(BTN_NEXT,INPUT_PULLUP);pinMode(BTN_ACT,INPUT);
  analogReadResolution(12);analogSetPinAttenuation(BAT_ADC,ADC_11db);
  tft.init();tft.setTextWrap(false,false);tft.setRotation(ROT);tft.fillScreen(TFT_BLACK);
  // Init NEW marker state (all zeros = no previous scan)
  memset(prevBSSIDs,0,sizeof(prevBSSIDs));
  memset(isNew,0,sizeof(isNew));
  invalidateRiskCache();
  lastInteractionMs=millis();
  showHome();
}

// ═══════════════════════════════════════════════════════════
// Loop  (Phase 4, unchanged except idleToSleepMs)
// ═══════════════════════════════════════════════════════════
void loop(){
  uint32_t now=millis();tickToast(now);
  if(now<ignoreInputUntilMs){delay(5);if(now-lastInteractionMs>idleToSleepMs())goToSleep();return;}
  idleTickAnimation(state);

  if(state==HOME){
    if(digitalRead(BTN_NEXT)==LOW||digitalRead(BTN_ACT)==LOW){
      if(chordHeld(1000)){lastInteractionMs=millis();settingsCursor=0;showSettings();state=SETTINGS;ignoreInputUntilMs=millis()+200;return;}
    }
    BtnEvent evR=readBtn(BTN_ACT),evL=readBtn(BTN_NEXT);
    if(evR==BTN_TAP||evR==BTN_LONG){lastInteractionMs=millis();doScanList();state=LIST;ignoreInputUntilMs=millis()+150;}
    else if(evL==BTN_TAP&&hasScannedOnce){lastInteractionMs=millis();showList();state=LIST;ignoreInputUntilMs=millis()+150;}
  }
  else if(state==LIST){
    if(digitalRead(BTN_NEXT)==LOW||digitalRead(BTN_ACT)==LOW){
      if(chordHeld(1000)){lastInteractionMs=millis();settingsCursor=0;showSettings();state=SETTINGS;ignoreInputUntilMs=millis()+200;return;}
    }
    BtnEvent evL=readBtn(BTN_NEXT),evR=readBtn(BTN_ACT);
    if(evL==BTN_TAP){lastInteractionMs=millis();if(netCount>0){sel=(sel+1)%netCount;updateListSelectionUIDirty();}ignoreInputUntilMs=millis()+80;}
    else if(evR==BTN_LONG){lastInteractionMs=millis();doScanList();state=LIST;ignoreInputUntilMs=millis()+150;}
    else if(evR==BTN_TAP){lastInteractionMs=millis();if(netCount>0){showAnalysis(nets[SAFE_SEL]);state=ANALYZE;}ignoreInputUntilMs=millis()+150;}
  }
  else if(state==ANALYZE){
    bool lLow=(digitalRead(BTN_NEXT)==LOW),rLow=(digitalRead(BTN_ACT)==LOW);
    if(lLow||rLow){
      uint32_t t0=millis();
      while(millis()-t0<220){if(digitalRead(BTN_NEXT)==LOW&&digitalRead(BTN_ACT)==LOW)break;delay(5);}
      if(digitalRead(BTN_NEXT)==LOW&&digitalRead(BTN_ACT)==LOW){
        lastInteractionMs=millis();
        while(digitalRead(BTN_NEXT)==LOW||digitalRead(BTN_ACT)==LOW)delay(5);
        PortalResult res=runPortalTest(nets[SAFE_SEL]);portalRes[SAFE_SEL]=res;
        showPortalResult(res);ignoreInputUntilMs=millis()+300;state=PORTAL_RESULT;return;
      }
      lLow=(digitalRead(BTN_NEXT)==LOW);rLow=(digitalRead(BTN_ACT)==LOW);
      if(lLow){lastInteractionMs=millis();while(digitalRead(BTN_NEXT)==LOW)delay(5);showList();state=LIST;ignoreInputUntilMs=millis()+150;return;}
      if(rLow){lastInteractionMs=millis();while(digitalRead(BTN_ACT)==LOW)delay(5);if(netCount>0){sel=(sel+1)%netCount;showAnalysis(nets[SAFE_SEL]);}ignoreInputUntilMs=millis()+150;return;}
    }
  }
  else if(state==PORTAL_RESULT){
    BtnEvent evL=readBtn(BTN_NEXT),evR=readBtn(BTN_ACT);
    if(evL!=BTN_NONE){lastInteractionMs=millis();showAnalysis(nets[SAFE_SEL]);state=ANALYZE;ignoreInputUntilMs=millis()+200;return;}
    if(evR!=BTN_NONE){lastInteractionMs=millis();showList();state=LIST;ignoreInputUntilMs=millis()+150;return;}
  }
  else if(state==SETTINGS){
    BtnEvent evL=readBtn(BTN_NEXT),evR=readBtn(BTN_ACT);
    if(evL==BTN_TAP){lastInteractionMs=millis();cycleSettingValue(settingsCursor);drawSettingsRow(settingsCursor);ignoreInputUntilMs=millis()+100;}
    else if(evR==BTN_TAP){
      lastInteractionMs=millis();
      if(settingsCursor<SETTINGS_ROWS-1){int p=settingsCursor++;drawSettingsRow(p);drawSettingsRow(settingsCursor);}
      else{saveSettings();if(netCount>0)sortNets();applyBrightness(settings.brightness);showToast("Settings saved",TFT_GREEN,1800);showHome();state=HOME;}
      ignoreInputUntilMs=millis()+120;
    }
    else if(evL==BTN_LONG){lastInteractionMs=millis();loadSettings();applyBrightness(settings.brightness);showToast("Settings cancelled",TFT_DARKGREY,1600);showHome();state=HOME;ignoreInputUntilMs=millis()+200;}
  }

  if(millis()-lastInteractionMs>idleToSleepMs())goToSleep();
  delay(20);
}

